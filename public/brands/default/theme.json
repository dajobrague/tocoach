{
  "meta": {
    "name": "TopCoach Default",
    "version": "1.0.0",
    "description": "Default TopCoach theme with professional blue palette"
  },
  "fonts": {
    "heading": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 600
    },
    "body": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 400
    }
  },
  "colors": {
    "brand": "#0ea5e9",
    "accent": "#0284c7",
    "text": {
      "primary": "#0f172a",
      "secondary": "#64748b"
    },
    "surface": {
      "1": "#ffffff",
      "2": "#f8fafc"
    },
    "border": "#e2e8f0",
    "fill": "#f1f5f9"
  },
  "radius": {
    "sm": 6,
    "md": 8,
    "lg": 12,
    "xl": 16
  },
  "shadow": {
    "e1": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "e2": "0 4px 6px rgba(0, 0, 0, 0.07)"
  },
  "semantic": {
    "success": "#22c55e",
    "warning": "#f59e0b",
    "error": "#ef4444"
  },
  "assets": {
    "logo": "/brands/default/logo.svg",
    "banner": "/brands/default/banner.svg"
  }
}
