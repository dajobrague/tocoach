{
  "meta": {
    "name": "IronFit",
    "version": "1.0.0",
    "description": "Bold fitness theme with strength-focused orange and black palette"
  },
  "fonts": {
    "heading": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 700
    },
    "body": {
      "family": "Inter, system-ui, sans-serif",
      "weight": 400
    }
  },
  "colors": {
    "brand": "#ea580c",
    "accent": "#dc2626",
    "text": {
      "primary": "#1c1917",
      "secondary": "#57534e"
    },
    "surface": {
      "1": "#fafaf9",
      "2": "#f5f5f4"
    },
    "border": "#e7e5e4",
    "fill": "#f5f5f4"
  },
  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20
  },
  "shadow": {
    "e1": "0 2px 4px rgba(234, 88, 12, 0.08)",
    "e2": "0 8px 16px rgba(234, 88, 12, 0.12)"
  },
  "semantic": {
    "success": "#16a34a",
    "warning": "#d97706",
    "error": "#dc2626"
  },
  "assets": {
    "logo": "/brands/ironfit/logo.svg",
    "banner": "/brands/ironfit/banner.svg"
  }
}
